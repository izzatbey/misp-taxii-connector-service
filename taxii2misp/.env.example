# Configuration variables for the TAXII to MISP service

# TAXII Server Configuration
# Note: as of 2026-07-13 the taxii-mv-proxy listens on port 9001 (not
# 9000, which is now reserved for the upstream OpenTAXII container).
# If you connect directly to OpenTAXII, use 9000; if you go through
# the proxy, use 9001.
DISCOVERY_URL=https://your-taxii-server:9001/taxii2/
USERNAME=admin
PASSWORD=your_password
VERIFY_SSL=false

# MISP Server Configuration
MISP_URL=https://your-misp-server/
MISP_API_KEY=your_misp_api_key
MISP_DISTRIBUTION_LEVEL=1
MISP_THREAT_LEVEL=2
MISP_ANALYSIS_LEVEL=2
MISP_ALERT_ON_PUBLISH=false

# Application Configuration
SCHEDULER_INTERVAL_SECONDS=3600
MAX_EVENTS_PER_RUN=50
TEMP_DIR=/tmp/taxii2misp
UPDATE_EXISTING_EVENTS=false
COMPREHENSIVE_PROCESSING=true

# Advanced Configuration
TAXII_REQUEST_TIMEOUT=300
TAXII_CHUNK_SIZE=1000

# Redis Configuration for Event Tracking
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_ENABLE_TRACKING=true
REDIS_TTL_SECONDS=86400

# Logging Configuration
LOG_LEVEL=INFO
