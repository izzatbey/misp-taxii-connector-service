OTX_API_KEY = '<your-otx-api-key>'
OTX_API_REDIS_HOST = redis
TAXII_URL = 'https://your-opentaxii-host:9000/taxii2/'
USERNAME = '<opentaxii-username>'
PASSWORD = '<opentaxii-password>'
VERIFY_SSL = False
MISP_URL = "https://your-misp-host/"
MISP_API_KEY = "<your-misp-api-key>"
TAXII_TEST_OBJECT_LIMIT=None
OTX_TEST_PULSE_LIMIT=None

# OTX Author Filter Configuration
# Set to a specific author name (e.g., "AlienVault") to only process pulses from that author
# Set to None, empty, or "ALL" to process pulses from ALL subscribed authors (recommended)
OTX_AUTHOR_FILTER=None

REDIS_HOST = 'localhost'
REDIS_PORT = 6379
REDIS_DB = 0
REDIS_PASSWORD =
CACHE_TTL_SECONDS=3600
CACHE_REFRESH_THRESHOLD=300
ENABLE_CACHE_PREVALIDATION=true
MAX_BUNDLES_TO_PUSH = None
SCHEDULER_INTERVAL_SECONDS=10

# Number of worker threads for concurrent per-pulse processing inside
# process_otx_to_taxii(). Default 6 is safe for SQLite-backed OpenTAXII;
# bump to 8-16 if your OpenTAXII uses PostgreSQL or MySQL.
MAX_WORKERS = 8