# TAXII MV-Proxy: read-only front-end that serves TAXII 2.1 reads
# against the opentaxii_stixobject_latest materialized view instead of
# going through OpenTAXII's slow SQL path.

# PostgreSQL connection (the same db-1 that OpenTAXII uses)
POSTGRES_HOST=db-1
POSTGRES_PORT=5432
POSTGRES_DB=opentaxii
POSTGRES_USER=security
POSTGRES_PASSWORD=

# The collection ID we serve. Set this to your SOCollection UUID.
# Optional: leave empty and pass ?collection_id=... query parameter instead.
DEFAULT_COLLECTION_ID=f14ba215-3f4c-4106-9979-2c818f6d9e76

# Upstream OpenTAXII (only used for /discovery, /collections metadata).
# Note: this URL still uses port 9000 because it points to the OpenTAXII
# container itself (opentaxii-1 binds 9000 internally). It is NOT the
# address clients use to reach this proxy.
UPSTREAM_TAXII_URL=https://opentaxii-1:9000/taxii2/

# Networking
# The proxy listens on port 9001 (was 9000, changed 2026-07-13) so it
# doesn't clash with the upstream OpenTAXII container. Update the
# taxii2misp connector's DISCOVERY_URL to use this port.
PROXY_HOST=0.0.0.0
PROXY_PORT=9001
PROXY_PUBLIC_URL=https://10.80.150.113:9001/taxii2/

# Auth the proxy accepts (forwarded to MV-row filter via collection access;
# the proxy does NOT validate user/pass at the HTTP layer — it runs on a
# closed network. If you want a public-facing proxy add bearer auth here.)
#
# Behavior: the proxy's discovery endpoint is a thin pass-through of
# UPSTREAM_TAXII_URL. /manifest/ and /objects/ are served directly
# from Postgres. They will return data for whatever collection the
# client requests; if you want per-user auth, layer FastAPI Depends-based
# auth in proxy.py and filter by allowed collection IDs.

# Pagination defaults
DEFAULT_PAGE_SIZE=200
MAX_PAGE_SIZE=1000
PAGE_SIZE_QUERY_PARAM=limit

# Logging
LOG_LEVEL=INFO
